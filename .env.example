# ─────────────────────────────────────────────────────────────────────────────
# AI Intelligence Dashboard — environment variable reference
#
# Copy this file to .env and fill in your values.
# All AIID_* variables override their corresponding value from config/feeds.yaml.
# ─────────────────────────────────────────────────────────────────────────────

# ── Feed / pipeline configuration ────────────────────────────────────────────

# Path to the feeds YAML config file (default: config/feeds.yaml)
# AIID_CONFIG_PATH=config/feeds.yaml

# How far back (in hours) to look for new articles (default: 48)
# AIID_LOOKBACK_HOURS=48

# How often the scheduler triggers a pipeline run, in minutes (default: 60)
# AIID_RUN_INTERVAL_MINUTES=60

# Maximum seconds a single pipeline run may take before being terminated (default: 300)
# AIID_PIPELINE_TIMEOUT_SECONDS=300

# ── Storage ───────────────────────────────────────────────────────────────────

# Path to the SQLite database file (default: data/articles.db)
# AIID_DB_PATH=data/articles.db

# Path for the JSON snapshot export (default: data/articles.json)
# AIID_JSON_EXPORT_PATH=data/articles.json

# ── LLM classification (Sprint 2) ────────────────────────────────────────────

# LLM provider to use for classification: "openai" or "anthropic" (default: unset)
# AIID_LLM_PROVIDER=openai

# Number of articles to send per LLM API batch (default: 20)
# AIID_LLM_BATCH_SIZE=20

# OpenAI API key (required when AIID_LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic API key (required when AIID_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Logging ───────────────────────────────────────────────────────────────────

# Log output format: "json" for structured JSON, any other value for human-readable (default: unset → human-readable)
# LOG_FORMAT=json

# Minimum log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Optional path for file log output; when unset logs go to stdout only
# LOG_FILE=/var/log/ai-intel-dashboard/app.log
